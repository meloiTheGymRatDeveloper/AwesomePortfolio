# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored.

# Resend API key — used by the contact form to send emails.
# Get one free at https://resend.com
# If left unset in development, the contact form will log submissions to
# the server console instead of sending them.
RESEND_API_KEY=

# Where to send contact form submissions.
# Should match a verified sender/recipient in your Resend account.
CONTACT_EMAIL_TO=hello@example.com
CONTACT_EMAIL_FROM=Portfolio Contact <contact@example.com>
